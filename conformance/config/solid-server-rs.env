# Conformance harness environment for solid-server-rs (the EXPERIMENTAL Rust track). Consumed via
# `docker run --env-file`. The auth path is documented in conformance/README.md.
#
# This reuses the SAME `solid` Keycloak realm + conformance-alice/bob DPoP service-account clients
# that prod-solid-server conformance uses (running at localhost:8080/realms/solid). The Rust server
# is booted with the IN-MEMORY store doubles + SOLID_SERVER_SEED_CONFORMANCE=1, which seeds the
# alice/bob WebID profiles (pim:storage → pod root, solid:oidcIssuer → the realm) + container tree
# the harness dereferences to bootstrap. See conformance/run.sh.
#
# The harness runs with `--network host`, so `localhost:8080` (Keycloak, a VM container) and
# `localhost:3000` (the server, via the socat sidecar in run.sh) are both reachable — exactly the
# hosts baked into the token claims. See conformance/README.md "Networking".

# --- Users -------------------------------------------------------------------------------------
# The harness dereferences each WebID over https to find its pim:storage (pod root). The Rust server
# serves these (seeded) over the in-process TLS listener at https://localhost:3000.
USERS_ALICE_WEBID=https://localhost:3000/alice/profile/card#me
USERS_BOB_WEBID=https://localhost:3000/bob/profile/card#me

# The Keycloak realm that issues tokens. The Rust server trusts this via SOLID_SERVER_TRUSTED_ISSUER
# (= http://localhost:8080/realms/solid, which the token `iss` matches and the server resolves to
# loopback — required by the verifier's SSRF guard). NOTE the trailing slash: the harness builds the
# discovery URL with URI.resolve(".well-known/..."), which drops the last path segment unless the
# issuer ends in `/`.
SOLID_IDENTITY_PROVIDER=http://localhost:8080/realms/solid/
USERS_ALICE_IDP=http://localhost:8080/realms/solid/
USERS_BOB_IDP=http://localhost:8080/realms/solid/

# --- Authentication: client-credentials grant against Keycloak ---------------------------------
# The harness exchanges these for DPoP-bound access tokens via the realm token endpoint (it adds the
# DPoP proof itself — Client.withDpopSupport). Each client's service account carries a hardcoded
# `webid` claim + the server-base `aud`, so the token is a valid RFC-9068 at+jwt Solid-OIDC DPoP token.
USERS_ALICE_CLIENTID=conformance-alice
USERS_ALICE_CLIENTSECRET=conformance-alice-secret
USERS_BOB_CLIENTID=conformance-bob
USERS_BOB_CLIENTSECRET=conformance-bob-secret

# --- Test container ----------------------------------------------------------------------------
# Where the harness creates/destroys test resources (relative to the storage found in alice's WebID).
# The Rust server seeds /{u}/test/ at boot.
TEST_CONTAINER=test/

# --- Harness behaviour -------------------------------------------------------------------------
ORIGIN=https://tester
# localhost self-signed TLS (the Rust server's in-process rustls listener with the tests/fixtures
# cert) is trusted by the harness for localhost hosts via ALLOW_SELF_SIGNED_CERTS (set in run.sh).
