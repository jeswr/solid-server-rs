@prefix solid-test: <https://github.com/solid/conformance-test-harness/vocab#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix earl: <http://www.w3.org/ns/earl#> .

# TestSubject for solid-server-rs (the EXPERIMENTAL parallel-track Rust server). `--target=solid-server-rs`
# selects this node. It claims the LDP/Solid surface the Rust server implements today (LDP CRUD,
# Turtle/JSON-LD content negotiation, conditional + Range requests, n3-patch PATCH, storage description +
# /.well-known/solid discovery, WebSocketChannel2023 notifications) AND the full Web Access Control
# suite — WAC is now implemented locally (the in-Rust engine in src/authz, evaluating .acl documents
# through the Store seam). The suite passes 41/41 (Protocol 25/25 + WAC 16/16). See
# conformance/SCORE.md for the per-suite breakdown.
<solid-server-rs>
    a earl:Software, earl:TestSubject ;
    doap:name "solid-server-rs" ;
    doap:release <solid-server-rs#release> ;
    doap:homepage <https://github.com/jeswr/solid-server-rs> ;
    doap:description "EXPERIMENTAL Rust Solid/LDP server: axum/hyper/tokio, SPARQ-authoritative metadata + access-control, object_store-backup bytes, DPoP/Solid-OIDC auth via solid-oidc-verifier."@en ;
    doap:programming-language "Rust" ;

    # --- Feature groups deliberately skipped (not applicable / unimplementable in this setup) -------
    # ACP is not implemented — authorization is Web Access Control only (the maintainer's directive:
    # SPARQ does WAC eval). ACP is out of scope for the Rust track.
    solid-test:skip "acp" ;
    # Group-based access (acl:agentGroup) resolution is a v1 follow-up; the WAC engine recognises the
    # predicate but never grants on it (fail-closed), so group-membership scenarios are skipped.
    solid-test:skip "wac-agent-group" ;
    # `@http-redirect` CORS scenarios open `http://localhost:3000/...` (the harness substitutes
    # `^https:` → `http:` WITHOUT changing the port) and expect a 301/308. The conformance setup runs
    # the Rust server on a single non-default port terminating TLS in-process, so it cannot also serve
    # plain HTTP on the same port — the scenario assumes default 443/80. Skip rather than fail on an
    # unimplementable-in-this-setup pattern (matches the prod-solid-server TestSubject rationale).
    solid-test:skip "http-redirect" ;

    rdfs:comment "EXPERIMENTAL Rust track. DPoP-bound tokens required (RFC 9449); tokens are RFC 9068 at+jwt with a mandatory audience (the server base URL). Web Access Control is implemented (the local in-Rust engine in src/authz); the suite passes 41/41 (Protocol 25/25 + WAC 16/16)."@en .

<solid-server-rs#release>
    doap:name "v0.1.0" ;
    doap:revision "0.1.0" ;
    doap:created "2026-06-22T00:00:00.000Z"^^xsd:dateTime .
